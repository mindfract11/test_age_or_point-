age = input("What is your age? ")
point = input("What is your point? ")

if not age.isdigit() or not point.isdigit():
    print("Please enter valid numbers!")
else:
    age = int(age)
    point = int(point)

    if age < 18:
        print("You are too young")
    elif point > 65:
        print("Well done! You passed the test")
    else:
        print("You need more points")
